import { ScrollView } from "std-widgets.slint";
import { Theme } from "theme.slint";

import { ButtonDemo } from "demos/button_demo.slint";
import { PanelDemo } from "demos/panel_demo.slint";
import { TextDemo } from "demos/text_demo.slint";
import { HoverDemo } from "demos/hover_demo.slint";
import { MotionDemo } from "demos/motion_demo.slint";
import { ThemeDemo } from "demos/theme_demo.slint";

// Root app window for Rust UI Style Playground.
// This file composes all sections and keeps top-level structure tutorial-friendly.
export component AppWindow inherits Window {
    title: "Rust UI Style Playground - Pass 1";
    width: 1200px;
    height: 920px;
    background: Theme.app-bg;

    // App shell with simple two-tone background for depth.
    Rectangle {
        background: Theme.app-bg;

        Rectangle {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: 160px;
            background: #171e2b;
        }

        VerticalLayout {
            spacing: Theme.space-md;
            padding: Theme.space-lg;

            Text {
                text: "Rust UI Style Playground";
                color: Theme.text-strong;
                font-size: 34px;
                font-weight: 750;
                horizontal-alignment: left;
                vertical-alignment: center;
            }

            Text {
                text: "A native Slint desktop lab for recreating polished style and interaction patterns often associated with CSS.";
                color: Theme.text-muted;
                font-size: 15px;
                wrap: word-wrap;
                horizontal-alignment: left;
                vertical-alignment: top;
            }

            // Scrollable body keeps all sections visible in a single window.
            ScrollView {
                VerticalLayout {
                    spacing: Theme.space-md;
                    padding-right: Theme.space-sm;

                    ButtonDemo {}
                    PanelDemo {}
                    TextDemo {}
                    HoverDemo {}
                    MotionDemo {}
                    ThemeDemo {}
                }
            }
        }
    }
}